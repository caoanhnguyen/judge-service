# ==========================================
# CẤU HÌNH HỆ THỐNG CHẤM BÀI (OJ SANDBOX)
# ==========================================

# 1. Thư mục trên máy Host (Windows/Linux)
JUDGE_WORK_DIR=/path/to/your/work-dir
JUDGE_CACHE_DIR=/path/to/your/testcases-cache

# 2. Thư mục và giới hạn bên trong Docker Container
CONTAINER_IMAGE_NAME=container-name
CONTAINER_WORK_DIR=/sandbox/app
CONTAINER_TESTCASE_DIR=/testcases
CONTAINER_MAX_OUTPUT_KB=32768
CONTAINER_MAX_OUTPUT_MB=31

# ==========================================
# CẤU HÌNH MINIO (LƯU TRỮ OBJECT)
# ==========================================
MINIO_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_BUCKET_TESTCASE=oj-testcases

# ==========================================
# CẤU HÌNH RABBITMQ (MESSAGE QUEUE)
# ==========================================
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password